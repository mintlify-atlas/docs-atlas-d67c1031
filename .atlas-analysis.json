  "keyFeatures": [
    "Raw material purchase-order intake control linked to an external SQL Server (Profit/Ceres Romana)",
    "Personnel access log with entry/exit timestamps, visit duration, and approval status",
    "Transport audit module for reviewing and editing orden_profit_transporte records",
    "PDF report generation (materia prima and personnel) via WeasyPrint",
    "Role-based permission system with per-module boolean flags and a read-only mode",
    "CLI user management tool (CreateUser.py) for bootstrapping admin credentials",
    "Autocomplete JSON endpoints for companies, drivers, vehicles, products, and people",
    "Session-based authentication with inactivity timeout and account locking"
  ],
  "publicApiSurface": [
    "GET/POST /control/ — raw-material order intake view",
    "GET/POST /control_personas/ — personnel access control view",
    "GET/POST /auditoria/ — transport audit view",
    "GET/POST /usuarios/ — user management view",
    "GET /reportes/ — report viewer",
    "GET /reporte_pdf/materia_prima/ — download materia prima PDF",
    "GET /reporte_pdf/personal/ — download personnel PDF",
    "GET /reporte_historial/ — download historial PDF",
    "GET /autocomplete/empresa/ — company autocomplete JSON",
    "GET /autocomplete/chuto/ — vehicle (chuto) autocomplete JSON",
    "GET /autocomplete/tanque/ — trailer autocomplete JSON",
    "GET /autocomplete/destino/ — destination autocomplete JSON",
    "GET /autocomplete/conductor/ — driver autocomplete JSON",
    "GET /autocomplete/producto/ — product autocomplete JSON",
    "GET /autocomplete/persona/nombre/ — person name autocomplete",
    "GET /autocomplete/persona/apellido/ — person surname autocomplete",
    "GET /autocomplete/persona/cedula/ — person ID autocomplete",
    "GET /autocomplete/persona/placa/ — person vehicle plate autocomplete",
    "GET /autocomplete/persona/empresa/ — person company autocomplete",
    "GET /autocomplete/persona/autorizado_por/ — authorizer autocomplete",
    "POST /login/ — session login",
    "GET /logout/ — session logout"
  ]
}
